# Database
DATABASE_URL="postgresql://postgres:password@host.railway.internal:5432/database"

# For production (Vercel), set DATABASE_URL in Vercel environment variables
# Get the public connection URL from Railway postgres service

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"  # e.g. dwheha9pb
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_UPLOAD_FOLDER="roshni/products"

# NextAuth (if implementing in future)
# NEXTAUTH_SECRET="your-secret-key-here"
# NEXTAUTH_URL="http://localhost:3000"

# Payment Gateway (bKash/Nagad)
# BKASH_API_KEY="your-bkash-api-key"
# NAGAD_API_KEY="your-nagad-api-key"

# Email Service (for order confirmations)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
